{
  "name": "@smithy-mcp/cdk",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/**/*.test.ts",
    "synth": "cdk synth",
    "cdk": "cdk",
    "deploy:staging": "cdk deploy --all --context environment=staging --require-approval never",
    "deploy:production": "cdk deploy --all --context environment=production --require-approval never",
    "destroy": "cdk destroy --all"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.261.0",
    "constructs": "^10.7.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "aws-cdk": "^2.1132.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
